{
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/((?!api/|.well-known/).*)", "destination": "/index.html" }
  ]
}
